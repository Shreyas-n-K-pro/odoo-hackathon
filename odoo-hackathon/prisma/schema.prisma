// ─────────────────────────────────────────────────────────────────────────────
// TransitOps — Prisma Schema (MySQL 8)
// ALL 8 tables live here. Everyone runs: npx prisma db push
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  Fleet_Manager     @map("Fleet Manager")
  Dispatcher
  Safety_Officer    @map("Safety Officer")
  Financial_Analyst @map("Financial Analyst")
}

enum VehicleType {
  Van
  Truck
  Mini
}

enum VehicleStatus {
  Available
  On_Trip   @map("On Trip")
  In_Shop   @map("In Shop")
  Retired
}

enum DriverStatus {
  Active
  On_Leave  @map("On Leave")
  Inactive
}

enum TripStatus {
  Scheduled
  In_Progress @map("In Progress")
  Completed
  Cancelled
}

enum MaintenanceType {
  Routine
  Repair
  Inspection
}

enum ExpenseCategory {
  Fuel
  Maintenance
  Toll
  Other
}

// ─── Table: users (Member A) ─────────────────────────────────────────────────

model User {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(100)
  email           String    @unique @db.VarChar(150)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  role            Role
  failedAttempts  Int       @default(0) @map("failed_attempts")
  lockedUntil     DateTime? @map("locked_until")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("users")
}

// ─── Table: vehicles (Member A) ──────────────────────────────────────────────

model Vehicle {
  id              Int           @id @default(autoincrement())
  regNumber       String        @unique @map("reg_number") @db.VarChar(20)
  name            String        @db.VarChar(100)
  type            VehicleType
  capacityKg      Decimal       @map("capacity_kg") @db.Decimal(10, 2)
  odometer        Int           @default(0)
  acquisitionCost Decimal       @map("acquisition_cost") @db.Decimal(12, 2)
  status          VehicleStatus @default(Available)
  region          String?       @db.VarChar(100)
  createdAt       DateTime      @default(now()) @map("created_at")

  // Relations
  trips            Trip[]
  maintenanceLogs  MaintenanceLog[]
  fuelLogs         FuelLog[]

  @@map("vehicles")
}

// ─── Table: settings (Member A) ──────────────────────────────────────────────

model Settings {
  id            Int    @id @default(1)
  depotName     String @default("Gandhinagar Depot GJ4") @map("depot_name") @db.VarChar(150)
  currency      String @default("INR (Rs)") @db.VarChar(10)
  distanceUnit  String @default("Kilometers") @map("distance_unit") @db.VarChar(20)

  @@map("settings")
}

// ─── Table: drivers (Member B) ───────────────────────────────────────────────

model Driver {
  id             Int          @id @default(autoincrement())
  name           String       @db.VarChar(100)
  licenseNumber  String       @unique @map("license_number") @db.VarChar(50)
  licenseExpiry  DateTime     @map("license_expiry")
  phone          String       @db.VarChar(20)
  status         DriverStatus @default(Active)
  region         String?      @db.VarChar(100)
  totalTrips     Int          @default(0) @map("total_trips")
  createdAt      DateTime     @default(now()) @map("created_at")

  // Relations
  trips Trip[]

  @@map("drivers")
}

// ─── Table: trips (Member B) ─────────────────────────────────────────────────

model Trip {
  id            Int        @id @default(autoincrement())
  tripCode      String     @unique @map("trip_code") @db.VarChar(30)
  vehicleId     Int        @map("vehicle_id")
  driverId      Int        @map("driver_id")
  origin        String     @db.VarChar(150)
  destination   String     @db.VarChar(150)
  scheduledAt   DateTime   @map("scheduled_at")
  completedAt   DateTime?  @map("completed_at")
  distanceKm    Decimal?   @map("distance_km") @db.Decimal(10, 2)
  status        TripStatus @default(Scheduled)
  notes         String?    @db.Text
  createdAt     DateTime   @default(now()) @map("created_at")

  // Relations
  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  driver   Driver    @relation(fields: [driverId], references: [id])
  expenses Expense[]

  @@map("trips")
}

// ─── Table: maintenance_logs (Member C) ──────────────────────────────────────

model MaintenanceLog {
  id            Int             @id @default(autoincrement())
  vehicleId     Int             @map("vehicle_id")
  type          MaintenanceType
  description   String          @db.Text
  cost          Decimal         @db.Decimal(12, 2)
  servicedAt    DateTime        @map("serviced_at")
  nextServiceAt DateTime?       @map("next_service_at")
  odometer      Int
  vendor        String?         @db.VarChar(150)
  createdAt     DateTime        @default(now()) @map("created_at")

  // Relations
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("maintenance_logs")
}

// ─── Table: fuel_logs (Member C) ─────────────────────────────────────────────

model FuelLog {
  id          Int      @id @default(autoincrement())
  vehicleId   Int      @map("vehicle_id")
  litres      Decimal  @db.Decimal(10, 2)
  pricePerLtr Decimal  @map("price_per_ltr") @db.Decimal(10, 2)
  totalCost   Decimal  @map("total_cost") @db.Decimal(12, 2)
  odometer    Int
  station     String?  @db.VarChar(150)
  filledAt    DateTime @map("filled_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("fuel_logs")
}

// ─── Table: expenses (Member C) ──────────────────────────────────────────────

model Expense {
  id          Int             @id @default(autoincrement())
  tripId      Int?            @map("trip_id")
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(12, 2)
  description String?         @db.VarChar(255)
  incurredAt  DateTime        @map("incurred_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  // Relations
  trip Trip? @relation(fields: [tripId], references: [id])

  @@map("expenses")
}
