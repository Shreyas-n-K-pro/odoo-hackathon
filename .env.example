# ─── Database ────────────────────────────────────────────────────────────────
# Replace <HOST_IP> with the IP of the machine hosting MySQL (shared by all 4 members)
DATABASE_URL="mysql://transitops_user:StrongPass123@<HOST_IP>:3306/transitops_db"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="transitops-super-secret-jwt-key-hackathon-2024"
